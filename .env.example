# Bibi Cycling Training Platform — Environment Variables Configuration

# --- Infrastructure & DB Config ---
POSTGRES_USER=bibi_admin
POSTGRES_PASSWORD=secure_password_replace_me
POSTGRES_DB=bibi_db
POSTGRES_HOST=bibi-postgres
POSTGRES_PORT=5432

# --- FastAPI Security & Auth ---
JWT_SECRET_KEY=generate_a_secure_random_hex_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Third-Party Integrations ---
# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_telegram_webhook_secret_here

# Intervals.icu Configuration
INTERVALS_ICU_CLIENT_ID=your_intervals_icu_client_id_here
INTERVALS_ICU_CLIENT_SECRET=your_intervals_icu_client_secret_here

# Strava Configuration (Optional Fallback)
STRAVA_CLIENT_ID=your_strava_client_id_here
STRAVA_CLIENT_SECRET=your_strava_client_secret_here

# --- AI & LLM Providers ---
# LiteLLM routes these to appropriate providers. Ensure the keys are set.
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model Curation
COACH_MODEL=gpt-4o-mini
REVIEWER_MODEL=claude-3-5-sonnet-20241022

# --- Application Tuning ---
# Max allowable CTL ramp rate per week (default: 7.0)
MAX_CTL_RAMP_RATE=7.0
# Guardrail TSS change allowance percentage (default: 0.20 = 20%)
TSS_GUARDRAIL_PERCENT=0.20
